# --- R / RStudio ---
.Rproj.user/
.Rhistory
.Rapp.history
.RData
.Ruserdata
*.Rproj.bak
# The RStudio project file (SEC.Rproj) is regenerated by RStudio; its ProjectId
# line caused spurious diffs/divergences, so it is not tracked. RStudio recreates
# it on open (File > Open Project, or New Project > Existing Directory).
*.Rproj

# --- renv (reproducible environment) ---
# The private package library is machine-specific and large -> never commit it.
# renv.lock IS committed (it records the exact versions). renv/activate.R and
# renv/settings.json (created by renv::init) ARE committed.
renv/library/
renv/local/
renv/cellar/
renv/staging/
renv/python/
renv/sandbox/
renv/lock/

# --- Knitted / cached output ---
*_cache/
*_files/
analysis/*_cache/
analysis/*_files/
*.utf8.md
*.knit.md

# --- Generated analysis output (regenerated by knitting; keep folders, ignore contents) ---
output/figures/*
output/tables/*
output/rdata/*
!output/figures/.gitkeep
!output/tables/.gitkeep
!output/rdata/.gitkeep

# Legacy output folders that the original .Rmd created at the project root.
# (The refactored .Rmd writes into output/ instead, but ignore these just in case.)
output_files/
RData_for_further_plotting_and_analysis/
DistinctAssembly_hits/
DistinctAssembly_hits_nolog2FC/

# --- Raw input data (often large / not shareable by default) ---
# Place your input files in data/raw/ (see data/raw/README.md). They are ignored
# by default. To deliberately include a (small, shareable) file in the handover,
# force-add it:  git add -f data/raw/your_file.xlsx
data/raw/*
!data/raw/README.md
!data/raw/.gitkeep

# --- OS cruft ---
.DS_Store
Thumbs.db
